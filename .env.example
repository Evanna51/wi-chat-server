PORT=8787
HOST=127.0.0.1
DATABASE_PATH=./data/character-behavior.db
VECTOR_INDEX_PATH=./data/vector-index.bin
VECTOR_META_PATH=./data/vector-meta.json
VECTOR_PROVIDER=hnswlib
VECTOR_DIM=256
VECTOR_K=20
APP_API_KEY=change-me
REQUIRE_API_KEY=0
DEBUG_HTTP_LOG=1

# Embedding service (OpenAI-compatible endpoint; optional)
EMBED_BASE_URL=
EMBED_MODEL=local-embedding

# Local Qwen (OpenAI-compatible API, e.g. LM Studio/vLLM/Ollama)
QWEN_BASE_URL=http://127.0.0.1:1234/v1
QWEN_API_KEY=not-required
QWEN_MODEL=qwen2.5:7b-instruct
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=200

# Retrieval and indexing
MEMORY_RETRIEVAL_ENABLED=1
RETRIEVAL_STRATEGY=v1
RETRIEVAL_TOP_K=8
RETRIEVAL_WINDOW_DAYS=30
INDEXER_BATCH_SIZE=20
INDEXER_RETRY_MAX=5
INDEXER_POLL_MS=2000

# Scheduler leader lock (legacy FCM proactive path, currently unused but kept)
LEGACY_FCM_PROACTIVE_LOCK_NAME=legacy_fcm_proactive_tick
SCHEDULER_LEADER_ID=local-1
SCHEDULER_LOCK_TTL_MS=60000

# FCM HTTP v1
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json

# legacy FCM proactive (temporarily unused, keep as rollback path)
LEGACY_FCM_PROACTIVE_CRON=off
LIFE_MEMORY_CRON=off
LIFE_MEMORY_LOCK_NAME=life_memory_tick
# Phase B plan executor 已接管主动消息调度；旧 cron 默认关闭，避免与 plan executor 双写 character_behavior_journal。
# 如需临时回滚到旧路径（不推荐），改为 "*/10 * * * *"。
PROACTIVE_MESSAGE_CRON=off
PROACTIVE_MESSAGE_LOCK_NAME=proactive_message_tick
# Phase B: nightly plan generation + per-minute dispatcher
PLAN_GENERATION_CRON=0 6 * * *
PLAN_GENERATION_LOCK_NAME=plan_generation_tick
PLAN_EXECUTOR_INTERVAL_MS=60000
AUTONOMOUS_ASSISTANT_IDS=
AUTONOMOUS_DRY_RUN=1
AUTONOMOUS_PUSH_ENABLED=0
AUTONOMOUS_QUIET_HOURS=0-7
AUTONOMOUS_MIN_MESSAGE_INTERVAL_MS=7200000
AUTONOMOUS_RECENT_USER_SILENCE_MS=1800000
AUTONOMOUS_SKIP_AFTER_INTERACTION_MS=600000
AUTONOMOUS_MESSAGE_CHECK_INTERVAL_MS=3600000
AUTONOMOUS_INACTIVE_7D_THRESHOLD_MS=604800000
AUTONOMOUS_INACTIVE_30D_THRESHOLD_MS=2592000000
AUTONOMOUS_MESSAGE_INTERVAL_AFTER_7D_MS=86400000
AUTONOMOUS_MESSAGE_INTERVAL_AFTER_30D_MS=604800000
LOCAL_PULL_MESSAGE_TTL_MS=604800000
LOCAL_PULL_REPULL_GAP_MS=15000
SCHEDULER_TIMEZONE=Asia/Shanghai

# Backup schedule
# 增量备份：每天 03:00 导出过去 25h 变更行到 data/backups/incr-YYYY-MM-DD.jsonl.gz
BACKUP_DAILY_CRON=0 3 * * *
# 全量备份：每周日 02:30 VACUUM INTO data/backups/full-YYYY-Www.sqlite
BACKUP_WEEKLY_CRON=30 2 * * 0
# 保留策略
BACKUP_INCR_KEEP_DAYS=8
BACKUP_FULL_KEEP_WEEKS=4
# 设为 "off" 可单独关闭某项
# BACKUP_DAILY_CRON=off
# BACKUP_WEEKLY_CRON=off

# Retention sweep (storage hygiene)
RETENTION_SWEEP_CRON=30 3 * * *
RETENTION_SWEEP_LOCK_NAME=retention_sweep_tick
RETENTION_RETRIEVAL_LOG_DAYS=30
RETENTION_OUTBOX_CONSUMED_DAYS=7
RETENTION_LOCAL_ACKED_DAYS=30
BEHAVIOR_JOURNAL_PRUNE_DAYS=90
